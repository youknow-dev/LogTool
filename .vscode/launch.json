{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run LogTool (Console)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/LogTool/bin/Debug/net10.0/LogTool.dll",
            "args": [
                "${workspaceFolder}/LogTool/UnitTest/test_log.txt",
                "--top", "5",
                "--level", "ERROR",
                "--output", "console"
            ],
            "cwd": "${workspaceFolder}/LogTool",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Run LogTool (File)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/LogTool/bin/Debug/net10.0/LogTool.dll",
            "args": [
                "${workspaceFolder}/LogTool/UnitTest/test_log.txt",
                "--top", "5",
                "--level", "ERROR",
                "--output", "./UnitTest/report"
            ],
            "cwd": "${workspaceFolder}/LogTool",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        }
    ]
}